{
  "name": "element-plus-crud",
  "version": "0.1.0",
  "description": "One-line CRUD page generator for Vue 3 + Element Plus",
  "author": "ZHANGKAI <zhangkai905106@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "type-check": "vue-tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vue3",
    "element-plus",
    "crud",
    "table",
    "admin",
    "dashboard",
    "vue",
    "typescript",
    "component",
    "low-code"
  ],
  "peerDependencies": {
    "element-plus": "^2.6.0",
    "vue": "^3.4.0"
  },
  "pnpm": {
    "overrides": {
      "vue": "3.5.35",
      "@vue/runtime-core": "3.5.35",
      "@vue/runtime-dom": "3.5.35",
      "@vue/reactivity": "3.5.35",
      "@vue/shared": "3.5.35",
      "@vue/compiler-sfc": "3.5.35",
      "@vue/compiler-dom": "3.5.35",
      "@vue/compiler-core": "3.5.35"
    }
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.10",
    "element-plus": "^2.6.0",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.2.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.2.12"
  }
}
